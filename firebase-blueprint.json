{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile document",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "dailyRate": { "type": "number", "description": "Local kWh rate" }
      },
      "required": ["name", "email", "createdAt"]
    },
    "Device": {
      "title": "Device",
      "description": "Electronic device tracked by the user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "type": { "type": "string" },
        "wattage": { "type": "number" },
        "count": { "type": "number" },
        "dailyUsageHours": { "type": "number" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["name", "wattage", "count", "dailyUsageHours", "createdAt", "userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "PLN Token purchase",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["type", "amount", "status", "createdAt", "userId"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["title", "message", "read", "createdAt", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User's public/private profile data"
    },
    "/users/{userId}/devices/{deviceId}": {
      "schema": { "$ref": "#/entities/Device" },
      "description": "User's tracked devices"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "User's billing history"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User's system notifications"
    }
  }
}
